{
  "manifest_version": 3,
  "name": "Resume Couturier AI",
  "version": "1.0",
  "description": "Chrome extension for Resume Couturier AI",
  "action": {},
  "side_panel": {
    "default_path": "sidemenu.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/*",
        "https://*.linkedin.ca/*",
        "https://*.linkedin.pk/*",
        "https://*.linkedin.co.uk/*",
        "https://*.glassdoor.com/*",
        "https://*.glassdoor.ca/*",
        "https://*.glassdoor.pk/*",
        "https://*.glassdoor.co.uk/*",
        "https://*.indeed.com/*",
        "https://*.indeed.ca/*",
        "https://*.indeed.pk/*",
        "https://*.indeed.co.uk/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "identity",
    "sidePanel",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "https://*.linkedin.com/*",
    "https://*.linkedin.ca/*",
    "https://*.linkedin.pk/*",
    "https://*.linkedin.co.uk/*",
    "https://*.glassdoor.com/*",
    "https://*.glassdoor.ca/*",
    "https://*.glassdoor.pk/*",
    "https://*.glassdoor.co.uk/*",
    "https://*.indeed.com/*",
    "https://*.indeed.ca/*",
    "https://*.indeed.pk/*",
    "https://*.indeed.co.uk/*"
  ],
  "oauth2": {
    "client_id": "755081361679-9l37cku2v462o7ffbbeo5r4q2vompc27.apps.googleusercontent.com",
    "scopes": [
      "openid",
      "email",
      "profile",
      "https://www.googleapis.com/auth/cloud-platform",
      "https://www.googleapis.com/auth/generative-language.retriever"
    ]
  }
}

{
  "manifest_version": 3,
  "name": "Resume Couturier AI",
  "version": "1.0",
  "description": "Chrome extension for Resume Couturier AI",
  "action": {},
  "side_panel": {
    "default_path": "sidemenu.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/*",
        "https://linkedin.com/*",
        "https://*.glassdoor.com/*",
        "https://glassdoor.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "identity",
    "sidePanel"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "https://*.linkedin.com/*",
    "https://linkedin.com/*",
    "https://*.glassdoor.com/*",
    "https://glassdoor.com/*"
  ],
  "oauth2": {
    "client_id": "104414854681-lj7j07dc4u77tivp4e3idbvap3ulnme7.apps.googleusercontent.com",
    "scopes": [
      "openid",
      "email",
      "profile",
      "https://www.googleapis.com/auth/cloud-platform",
      "https://www.googleapis.com/auth/generative-language.retriever"
    ]
  }
}
